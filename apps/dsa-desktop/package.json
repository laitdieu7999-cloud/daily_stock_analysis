{
  "name": "daily-stock-analysis-desktop",
  "version": "3.14.2",
  "private": true,
  "description": "Desktop shell for the Daily Stock Analysis local market analysis system.",
  "author": "Daily Stock Analysis Contributors",
  "main": "main.js",
  "devDependencies": {
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.electron.daily-stock-analysis-desktop",
    "productName": "daily-stock-analysis-desktop",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../dist/backend",
        "to": "backend"
      },
      {
        "from": "../../.env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "127.0.0.1": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionMinimumTLSVersion": "1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "localhost": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionMinimumTLSVersion": "1.0",
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            }
          }
        }
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "include": "installer.nsh"
    }
  }
}
